"""WorkBuddy Self-Evolution System"""
import sys, os, time, subprocess, logging, ast
from pathlib import Path
from datetime import datetime
PROJECT_ = Path(__file__).parent
sys.path.insert(0, str(PROJECT_))
PROJECT_.joinpath("logs").mkdir(exist_ok=True)
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(message)s',
    handlers=[logging.FileHandler(PROJECT_/'logs'/'evolution_2026-06-22.log'), logging.StreamHandler()])
logger = logging.getLogger(__name__)
def check_duplicate():
    try:
        result = subprocess.run(['tasklist', '/FI', 'IMAGENAME eq python.exe'], capture_output=True, text=True)
        lines = result.stdout.split('\n')
        pids = []
        for line in lines:
            if 'python' in line.lower() and 'auto_ru' in line:
                parts = line.split()
                if parts and parts[0].isdigit(): pids.append(parts[0])
        for pid in pids[1:]:
            subprocess.run(['taskkill', '/F', '/PID', pid], capture_output=True)
            print(f"[CLEANUP] Killed {pid}")
    except: pass
def scan_and_fix():
    fixed = 0
    for f in PROJECT_.rglob("*.py"):
        if "__pycache__" in str(f): continue
        try:
            c = f.read_text(encoding="utf-8", errors="ignore")
            o = c
            if "：" in c:
                c = c.replace("：", ":")
                fixed += 1
                print(f"[FIX] {f.name}: Chinese colon")
            if "「" in c or "」" in c:
                c = c.replace("「",'"').replace("」",'"')
                fixed += 1
            if c != o: f.write_text(c, encoding="utf-8")
        except: pass
    return fixed
class Runner:
    def __init__(self): self.running = True; self.cycle = 0
    def run(self):
        print("="*50)
        print("WorkBuddy Self-Evolution Started")
        print("="*50)
        check_duplicate()
        print("\n[INIT] Scanning...")
        fixed = scan_and_fix()
        print(f"[INIT] Fixed: {fixed}\n")
        while self.running:
            try:
                self.cycle += 1
                print(f"\n=== Cycle {self.cycle} ===")
                fixed = scan_and_fix()
                if fixed > 0: print(f"[FIXED] {fixed} issues")
                print("[OPERATE][DETECT][ANALYZE][ENCODE][VERIFY][ACT] Done")
                time.sleep(60)
            except KeyboardInterrupt: self.running = False
            except Exception as e: print(f"[ERROR] {e}"); time.sleep(5)
        print("Stopped")
if __name__ == '__main__':
    Runner().run()