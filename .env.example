# ========================================
# 完美自我进化系统 - 配置文件
# ========================================
# 请复制此文件为 .env 并填入你的API Key
# 
# 获取API Key: https://siliconflow.cn
# ========================================

# 必填：硅基流动API Key
LLM_API_KEY=sk-your-api-key-here

# API地址（一般不需要修改）
LLM_BASE_URL=https://api.siliconflow.cn/v1

# 模型（一般不需要修改）
LLM_MODEL=deepseek-ai/DeepSeek-R1

# 进化循环间隔（分钟）
EVOLUTION_INTERVAL=5

# 错误阈值（连续失败多少次触发技能生成）
ERROR_THRESHOLD=3

# 是否自动运行（true/false）
AUTO_RUN=true